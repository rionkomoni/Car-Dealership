PORT=5000
# Match the database name you created in phpMyAdmin
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=car_dealership
# Set to true only if you want the API to CREATE DATABASE (usually not needed once phpMyAdmin DB exists)
MYSQL_AUTO_CREATE_DB=false
# MongoDB: contacts + car activity logs (Compass / Atlas / local mongod)
MONGO_URI=mongodb://127.0.0.1:27017/car_dealership
JWT_SECRET=sekreti123
# Admin login (created or promoted on API startup)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678
MANAGER_EMAIL=manager@gmail.com
MANAGER_PASSWORD=12345678
